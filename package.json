{
  "name": "nextjs-project",
  "version": "1.0.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --parallel",
    "kill-ports": "lsof -ti:3000,3001 | xargs kill -9 2>/dev/null || true",
    "dev-clean": "npm run kill-ports && npm run dev"
  },
  "devDependencies": {
    "turbo": "^2.8.17"
  }
}
